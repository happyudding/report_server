# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# PyInstaller build output (build_honey.spec is kept as source)
build/
dist/
*.manifest
*.log

# Honey ZIP release output
client/release_dist/

# Locally generated report xlsx (regenerated by the report_generator)
client/data/
client/data/*_report.xlsx

# Runtime artifacts (regenerated at runtime)
DB/
uploads/
tests/sample.xlsx

# 프로파일러 산출물 (profile_run.py 가 생성)
client/_profiles/

# MS Office lock/owner files (e.g. ~$sample.xlsx when opened in Excel)
~$*

# Honey release packages served by /honey/download, not version-controlled.
# version.json IS tracked; release_honey.ps1 drops ZIP packages here.
server/releases/*.exe
server/releases/*.zip

# Local Claude Code settings (personal, not shared)
.claude/settings.local.json

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
